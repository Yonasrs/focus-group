<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Focus Group Report — FocusAI</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #F7F4EF;
    --bg2: #EDE9E2;
    --surface: #FFFFFF;
    --border: #DDD8CF;
    --text: #1A1714;
    --text2: #5C5650;
    --text3: #8C877F;
    --accent: #C84B2F;
    --accent2: #E8A87C;
    --accent-soft: #FBF0EB;
    --green: #2B7A5C;
    --green-soft: #EAF4EF;
    --yellow: #D97706;
    --yellow-soft: #FEF9EC;
    --radius: 16px;
    --shadow: 0 2px 12px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04);
    --shadow-lg: 0 8px 40px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.06);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: 16px;
    line-height: 1.6;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 40px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Instrument Serif', serif;
    font-size: 22px;
    color: var(--text);
    text-decoration: none;
  }

  .logo-dot {
    width: 10px;
    height: 10px;
    background: var(--accent);
    border-radius: 50%;
    display: inline-block;
  }

  .nav-right {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .nav-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 18px;
    border-radius: 10px;
    cursor: pointer;
    text-decoration: none;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text2);
    transition: all 0.2s;
  }

  .nav-btn:hover { background: var(--bg2); }

  .nav-btn.primary {
    background: var(--text);
    color: white;
    border-color: var(--text);
  }

  .nav-btn.primary:hover { background: var(--accent); border-color: var(--accent); }

  /* REPORT HEADER */
  .report-header {
    max-width: 900px;
    margin: 0 auto;
    padding: 56px 24px 40px;
  }

  .report-eyebrow {
    font-size: 12px;
    font-weight: 500;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }

  .report-title {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(30px, 5vw, 44px);
    font-weight: 400;
    color: var(--text);
    margin-bottom: 12px;
  }

  .report-meta {
    font-size: 14px;
    color: var(--text3);
  }

  /* FINAL SCORE BANNER */
  .score-banner {
    max-width: 900px;
    margin: 0 auto 40px;
    padding: 0 24px;
  }

  .score-card {
    background: var(--text);
    color: white;
    border-radius: var(--radius);
    padding: 32px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .score-left {}

  .score-label {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
    margin-bottom: 8px;
  }

  .score-value {
    font-family: 'Instrument Serif', serif;
    font-size: 64px;
    line-height: 1;
    color: white;
  }

  .score-value span {
    font-size: 28px;
    opacity: 0.4;
  }

  .score-summary {
    flex: 1;
    min-width: 240px;
  }

  .score-summary p {
    font-size: 15px;
    opacity: 0.85;
    line-height: 1.6;
  }

  .score-breakdown {
    display: flex;
    gap: 24px;
  }

  .score-mini {
    text-align: center;
  }

  .score-mini-val {
    font-family: 'Instrument Serif', serif;
    font-size: 28px;
    color: white;
    line-height: 1;
  }

  .score-mini-label {
    font-size: 11px;
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 4px;
  }

  /* SECTION */
  .section {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px 48px;
  }

  .section-heading {
    font-family: 'Instrument Serif', serif;
    font-size: 24px;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  /* PERSONA CARDS */
  .personas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }

  .persona-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.2s, box-shadow 0.2s;
    animation: card-in 0.4s ease both;
  }

  .persona-card:nth-child(1) { animation-delay: 0.05s; }
  .persona-card:nth-child(2) { animation-delay: 0.10s; }
  .persona-card:nth-child(3) { animation-delay: 0.15s; }
  .persona-card:nth-child(4) { animation-delay: 0.20s; }
  .persona-card:nth-child(5) { animation-delay: 0.25s; }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .persona-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .persona-card-header {
    padding: 20px 20px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .persona-card-id {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .persona-emoji {
    font-size: 28px;
  }

  .persona-name {
    font-weight: 600;
    font-size: 16px;
    color: var(--text);
  }

  .persona-type {
    font-size: 12px;
    color: var(--text3);
  }

  .stop-scrolling-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 100px;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stop-yes {
    background: var(--green-soft);
    color: var(--green);
    border: 1px solid rgba(43,122,92,0.2);
  }

  .stop-no {
    background: #FEF2F0;
    color: var(--accent);
    border: 1px solid rgba(200,75,47,0.2);
  }

  .persona-card-body {
    padding: 20px;
  }

  /* SCORE BARS */
  .score-bars {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 12px;
    margin-bottom: 16px;
  }

  .score-bar-item {
    text-align: center;
  }

  .score-bar-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text3);
    margin-bottom: 6px;
    font-weight: 500;
  }

  .score-bar-track {
    height: 6px;
    background: var(--bg2);
    border-radius: 100px;
    overflow: hidden;
    margin-bottom: 4px;
  }

  .score-bar-fill {
    height: 100%;
    border-radius: 100px;
    transition: width 0.8s cubic-bezier(0.4,0,0.2,1);
  }

  .fill-attention { background: #F4A261; }
  .fill-trust { background: #2B7A5C; }
  .fill-interest { background: #7C5CBF; }

  .score-bar-val {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
  }

  /* REACTION */
  .reaction-text {
    font-size: 14px;
    color: var(--text2);
    margin-bottom: 14px;
    line-height: 1.55;
  }

  .objection-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-bottom: 4px;
  }

  .objection-text {
    font-size: 13px;
    color: var(--text2);
    margin-bottom: 14px;
    line-height: 1.5;
  }

  .persona-quote {
    background: var(--bg);
    border-left: 3px solid var(--border);
    padding: 12px 14px;
    border-radius: 0 8px 8px 0;
    font-size: 14px;
    color: var(--text2);
    font-style: italic;
    line-height: 1.55;
  }

  /* COLOR ACCENT STRIPE */
  .persona-stripe {
    height: 4px;
  }

  /* MODERATOR REPORT */
  .moderator-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .moderator-header {
    background: var(--text);
    color: white;
    padding: 28px 32px;
  }

  .moderator-header h3 {
    font-family: 'Instrument Serif', serif;
    font-size: 22px;
    font-weight: 400;
    margin-bottom: 4px;
  }

  .moderator-header p {
    font-size: 14px;
    opacity: 0.6;
  }

  .moderator-body {
    padding: 32px;
  }

  .insight-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }

  .insight-block {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
  }

  .insight-block.positive {
    background: var(--green-soft);
    border-color: rgba(43,122,92,0.2);
  }

  .insight-block.negative {
    background: var(--accent-soft);
    border-color: rgba(200,75,47,0.2);
  }

  .insight-block.angle {
    grid-column: 1 / -1;
    background: var(--yellow-soft);
    border-color: rgba(217,119,6,0.2);
  }

  .insight-block-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--text3);
    margin-bottom: 8px;
  }

  .insight-block.positive .insight-block-label { color: var(--green); }
  .insight-block.negative .insight-block-label { color: var(--accent); }
  .insight-block.angle .insight-block-label { color: var(--yellow); }

  .insight-block p {
    font-size: 15px;
    color: var(--text);
    line-height: 1.55;
  }

  .insight-block.angle p {
    font-family: 'Instrument Serif', serif;
    font-size: 20px;
    font-style: italic;
  }

  .list-group {
    margin-bottom: 24px;
  }

  .list-group-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 10px;
  }

  .list-items {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .list-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--text2);
    line-height: 1.5;
  }

  .list-item-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .dot-green { background: var(--green-soft); color: var(--green); }
  .dot-red { background: var(--accent-soft); color: var(--accent); }
  .dot-blue { background: #EEF4FB; color: #457B9D; }
  .dot-orange { background: var(--yellow-soft); color: var(--yellow); }

  .lists-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }

  .risk-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }

  .risk-block {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
  }

  .risk-block-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text2);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .risk-block p {
    font-size: 14px;
    color: var(--text2);
    line-height: 1.55;
  }

  /* NO DATA STATE */
  .no-data {
    text-align: center;
    padding: 80px 24px;
  }

  .no-data p {
    font-size: 16px;
    color: var(--text3);
    margin-bottom: 24px;
  }

  @media (max-width: 600px) {
    nav { padding: 16px 20px; }
    .score-card { padding: 24px 20px; }
    .insight-row, .lists-grid, .risk-row { grid-template-columns: 1fr; }
    .insight-block.angle { grid-column: 1; }
    .moderator-body { padding: 20px; }
    .score-breakdown { display: none; }
  }
</style>
</head>
<body>

<nav>
  <a href="/" class="logo">
    <span class="logo-dot"></span>
    FocusAI
  </a>
  <div class="nav-right">
    <a href="/" class="nav-btn">← New Analysis</a>
  </div>
</nav>

<div id="reportContent">
  <div class="no-data">
    <p>Loading report…</p>
  </div>
</div>

<script>
const PERSONA_COLORS = {
  skeptic: '#E85D4A',
  emotional: '#7C5CBF',
  rational: '#2B7A78',
  trendy: '#F4A261',
  conservative: '#457B9D'
};

function scoreColor(val) {
  if (val >= 7) return '#2B7A5C';
  if (val >= 5) return '#D97706';
  return '#C84B2F';
}

function renderScoreBar(label, val, fillClass) {
  return `
    <div class="score-bar-item">
      <div class="score-bar-label">${label}</div>
      <div class="score-bar-track">
        <div class="score-bar-fill ${fillClass}" style="width: ${val*10}%"></div>
      </div>
      <div class="score-bar-val" style="color:${scoreColor(val)}">${val}</div>
    </div>
  `;
}

function renderPersonaCard(r) {
  const p = r.persona;
  const color = p.color || PERSONA_COLORS[p.id] || '#999';
  const stop = r.would_stop_scrolling;
  return `
    <div class="persona-card">
      <div class="persona-stripe" style="background: ${color}"></div>
      <div class="persona-card-header">
        <div class="persona-card-id">
          <span class="persona-emoji">${p.emoji}</span>
          <div>
            <div class="persona-name">${p.name}</div>
            <div class="persona-type">${p.label}</div>
          </div>
        </div>
        <span class="stop-scrolling-badge ${stop ? 'stop-yes' : 'stop-no'}">
          ${stop ? '✓ Would Stop' : '✗ Scrolls Past'}
        </span>
      </div>
      <div class="persona-card-body">
        <div class="score-bars">
          ${renderScoreBar('Attention', r.attention_score, 'fill-attention')}
          ${renderScoreBar('Trust', r.trust_score, 'fill-trust')}
          ${renderScoreBar('Interest', r.interest_score, 'fill-interest')}
        </div>
        <div class="reaction-text">${r.first_reaction}</div>
        <div class="objection-label">Main Objection</div>
        <div class="objection-text">${r.main_objection}</div>
        <div class="persona-quote">"${r.quote}"</div>
      </div>
    </div>
  `;
}

function avg(arr, key) {
  return (arr.reduce((s, r) => s + (r[key] || 0), 0) / arr.length).toFixed(1);
}

function renderListItems(items, dotClass, symbol) {
  if (!items || !items.length) return '<div class="list-item"><span>—</span></div>';
  return items.map(i => `
    <div class="list-item">
      <span class="list-item-dot ${dotClass}">${symbol}</span>
      <span>${i}</span>
    </div>
  `).join('');
}

function renderReport(data) {
  const { personas, moderator } = data;
  const avgAttention = avg(personas, 'attention_score');
  const avgTrust = avg(personas, 'trust_score');
  const avgInterest = avg(personas, 'interest_score');
  const stopCount = personas.filter(r => r.would_stop_scrolling).length;

  const html = `
    <div class="report-header">
      <div class="report-eyebrow">Focus Group Report</div>
      <div class="report-title">Your Ad Feedback</div>
      <div class="report-meta">${personas.length} personas reviewed · Generated just now</div>
    </div>

    <div class="score-banner">
      <div class="score-card">
        <div class="score-left">
          <div class="score-label">Overall Score</div>
          <div class="score-value">${moderator.final_score || '—'}<span>/10</span></div>
        </div>
        <div class="score-summary">
          <p>${moderator.executive_summary || ''}</p>
        </div>
        <div class="score-breakdown">
          <div class="score-mini">
            <div class="score-mini-val">${avgAttention}</div>
            <div class="score-mini-label">Attention</div>
          </div>
          <div class="score-mini">
            <div class="score-mini-val">${avgTrust}</div>
            <div class="score-mini-label">Trust</div>
          </div>
          <div class="score-mini">
            <div class="score-mini-val">${avgInterest}</div>
            <div class="score-mini-label">Interest</div>
          </div>
          <div class="score-mini">
            <div class="score-mini-val">${stopCount}/5</div>
            <div class="score-mini-label">Stop Scroll</div>
          </div>
        </div>
      </div>
    </div>

    <div class="section">
      <h2 class="section-heading">Persona Reactions</h2>
      <div class="personas-grid">
        ${personas.map(renderPersonaCard).join('')}
      </div>
    </div>

    <div class="section">
      <h2 class="section-heading">Moderator's Report</h2>
      <div class="moderator-section">
        <div class="moderator-header">
          <h3>Senior Moderator Analysis</h3>
          <p>Synthesized from all 5 persona responses</p>
        </div>
        <div class="moderator-body">

          <div class="insight-row">
            <div class="insight-block positive">
              <div class="insight-block-label">Strongest Positive Signal</div>
              <p>${moderator.strongest_positive || '—'}</p>
            </div>
            <div class="insight-block negative">
              <div class="insight-block-label">Strongest Risk</div>
              <p>${moderator.strongest_negative || '—'}</p>
            </div>
          </div>

          <div class="lists-grid">
            <div class="list-group">
              <div class="list-group-title">Likely Strengths</div>
              <div class="list-items">
                ${renderListItems(moderator.likely_strengths, 'dot-green', '✓')}
              </div>
            </div>
            <div class="list-group">
              <div class="list-group-title">Likely Weaknesses</div>
              <div class="list-items">
                ${renderListItems(moderator.likely_weaknesses, 'dot-red', '!')}
              </div>
            </div>
          </div>

          <div class="risk-row">
            <div class="risk-block">
              <div class="risk-block-title">⚡ Attention Risks</div>
              <p>${moderator.attention_risks || '—'}</p>
            </div>
            <div class="risk-block">
              <div class="risk-block-title">🔒 Trust Risks</div>
              <p>${moderator.trust_risks || '—'}</p>
            </div>
          </div>

          <div class="list-group">
            <div class="list-group-title">Recommended Improvements</div>
            <div class="list-items">
              ${renderListItems(moderator.recommended_improvements, 'dot-blue', '→')}
            </div>
          </div>

          <div class="insight-row">
            <div class="insight-block" style="background:#EEF4FB;border-color:rgba(69,123,157,0.2)">
              <div class="insight-block-label" style="color:#457B9D">Main Agreements</div>
              <div class="list-items" style="margin-top:4px">
                ${renderListItems(moderator.main_agreements, 'dot-blue', '·')}
              </div>
            </div>
            <div class="insight-block">
              <div class="insight-block-label">Points of Disagreement</div>
              <div class="list-items" style="margin-top:4px">
                ${renderListItems(moderator.main_disagreements, 'dot-orange', '·')}
              </div>
            </div>
          </div>

          <div class="insight-row">
            <div class="insight-block angle">
              <div class="insight-block-label">Suggested Ad Angle to Test</div>
              <p>${moderator.suggested_angle || '—'}</p>
            </div>
          </div>

        </div>
      </div>
    </div>
  `;

  document.getElementById('reportContent').innerHTML = html;
  setTimeout(() => {
    document.querySelectorAll('.score-bar-fill').forEach(bar => {
      const w = bar.style.width;
      bar.style.width = '0';
      setTimeout(() => { bar.style.width = w; }, 100);
    });
  }, 200);
}

const raw = sessionStorage.getItem('focusGroupResult');
if (raw) {
  try {
    renderReport(JSON.parse(raw));
  } catch(e) {
    document.getElementById('reportContent').innerHTML = `<div class="no-data"><p>Error rendering report. <a href="/">Try again.</a></p></div>`;
  }
} else {
  document.getElementById('reportContent').innerHTML = `<div class="no-data"><p>No report data found. <a href="/">Run an analysis first.</a></p></div>`;
}
</script>
</body>
</html>
